{
    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "custom/media",
    ],
    "modules-center": [
        "clock",
        "custom/voxtype"
    ],
    "modules-right": [
        "tray",
        "cpu",
        "memory",
        "custom/wireplumber",
        "battery",
    ],
    "clock": {
        "format": "{:%H:%M - %d/%m/%Y}"
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "tray": {
        "spacing": 10
    },
    "cpu": {
        "interval": 5,
        "format": "Ôíľ {usage}%",
        "tooltip": true,
        "on-click": "alacritty -e htop"
    },
    "memory": {
        "format": "ÔÉČ {percentage}%",
        "tooltip": true,
        "tooltip-format": " RAM used: {used:0.2f}/{total:0.2f} GB ({avail:0.2f} avail)\nSwap used: {swapUsed:0.2f}/{swapTotal:0.2f} GB ({swapAvail:0.2f} avail)",
        "on-click": "alacritty -e htop",
    },
    "temperature": {
        "critical-threshold": 80,
        "interval": 5,
        "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "format": "{temperatureC}¬įC {icon}",
        "format-icons": [
            "ůĪ©Ī",
            "ÔčČ",
            "ÔĚ©"
        ]
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": [
            "ÔÜÖ",
            "ÔĄĎ"
        ]
    },
    "custom/wireplumber": {
        "exec": "~/.config/waybar/wireplumber_status.sh",
        "return-type": "json",
        "interval": 2,
        "on-click": "select-default-audio",
        "on-click-right": "pavucontrol"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "{capacity}% ůįāĄ",
        "format-plugged": "{capacity}% Ôá¶",
        "format-alt": "{time} {icon}",
        "format-icons": [
            "ÔČĄ",
            "ÔČÉ",
            "ÔČā",
            "ÔČĀ",
            "ÔČÄ"
        ]
    },
    "network#wired": {
        "interface": "enp*",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr} ůįąÄ",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "ůįąÄ",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "alacritty -e nmtui"
    },
    "network#wireless": {
        "interface": "wlp*",
        "format-wifi": "{essid} {icon}",
        "format-linked": "{ifname} (No IP) ÔěĖ",
        "format-disconnected": "ůįĖ™",
        "tooltip-format-wifi": "{ifname}: {ipaddr}/{cidr}\nStrength: {signaldBm} dBm ({signalStrength}%)\nFrequency: {frequency} MHz",
        "on-click": "alacritty -e nmtui",
        "format-icons": ["ůį§Į", "ůį§ü", "ůį§Ę", "ůį§•", "ůį§®"]
    },
    "custom/vpn": {
        "format": "ůįĖā {}",
        "exec": "~/.config/waybar/vpn_status.sh",
        "interval": 30,
        "signal": 1,
        "return-type": "json",
        "on-click": "vpn"
    },
    "custom/voxtype": {
        "exec": "voxtype status --follow --format json",
        "return-type": "json",
        "format": "{icon}",
        "format-icons": {
            "idle": "ůįć¨",
            "recording": "ÔĄį",
            "transcribing": "ůĪČļ",
            "stopped": "ůįć≠"
        },
        "tooltip": true,
        "on-click": "systemctl --user restart voxtype"
    }
}
