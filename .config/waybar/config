{
    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "custom/media",
    ],
    "modules-center": [
        "clock",
        "custom/voxtype"
    ],
    "modules-right": [
        "tray",
        "network#wireless",
        "cpu",
        "memory",
        "custom/wireplumber",
        "battery",
    ],
    "clock": {
        "format": "{:%H:%M - %d/%m/%Y}"
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "tray": {
        "spacing": 10
    },
    "cpu": {
        "interval": 5,
        "format": "ο£Φ {usage}%",
        "tooltip": true,
        "on-click": "alacritty -e htop"
    },
    "memory": {
        "format": "οÉâ {percentage}%",
        "tooltip": true,
        "tooltip-format": " RAM used: {used:0.2f}/{total:0.2f} GB ({avail:0.2f} avail)\nSwap used: {swapUsed:0.2f}/{swapTotal:0.2f} GB ({swapAvail:0.2f} avail)",
        "on-click": "alacritty -e htop",
    },
    "temperature": {
        "critical-threshold": 80,
        "interval": 5,
        "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "format": "{temperatureC}¬ΑC {icon}",
        "format-icons": [
            "σ±©±",
            "ο΄â",
            "οù©"
        ]
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": [
            "οÜÖ",
            "ο³ë"
        ]
    },
    "custom/wireplumber": {
        "exec": "~/.config/waybar/wireplumber_status.sh",
        "return-type": "json",
        "interval": 2,
        "on-click": "select-default-audio",
        "on-click-right": "pavucontrol"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "{capacity}% σΑ²³",
        "format-plugged": "{capacity}% ο΅Π",
        "format-alt": "{time} {icon}",
        "format-icons": [
            "οâ³",
            "οâÉ",
            "οâ²",
            "οâ¹",
            "οâÄ"
        ]
    },
    "network#wired": {
        "interface": "enp*",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr} σΑàÄ",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "σΑàÄ",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}"
