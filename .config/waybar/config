        "format-linked": "{ifname} (No IP) οû•",
        "format-disconnected": "σΑ•Σ",
        "tooltip-format-wifi": "{ifname}: {ipaddr}/{cidr}\nStrength: {signaldBm} dBm ({signalStrength}%)\nFrequency: {frequency} MHz",
        "on-click": "alacritty -e impala",
        "format-icons": ["σΑΛ·", "σΑΛü", "σΑΛΔ", "σΑΛΞ", "σΑΛ®"]
    },
    "custom/vpn": {
        "format": "σΑ•² {}",
        "exec": "~/.config/waybar/vpn_status.sh",
        "interval": 30,
        "signal": 1,
        "return-type": "json",
        "on-click": "vpn"
    },
    "custom/voxtype": {
        "exec": "voxtype status --follow --format json",
        "return-type": "json",
        "format": "{icon}",
        "format-icons": {
            "idle": "σΑç§",
