{
    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "custom/media",
    ],
    "modules-center": [
        "clock",
        "custom/voxtype"
    ],
    "modules-right": [
        "tray",
        "cpu",
        "memory",
        "wireplumber",
        "bluetooth",
        "battery",
    ],
    "clock": {
        "format": "{:%H:%M - %d/%m/%Y}"
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "tray": {
        "spacing": 10
    },
    "cpu": {
        "interval": 5,
        "format": "ΎΤ╝ {usage}%",
        "tooltip": true,
        "on-click": "alacritty -e htop"
    },
    "memory": {
        "format": "ΎΔΚ {percentage}%",
        "tooltip": true,
        "tooltip-format": " RAM used: {used:0.2f}/{total:0.2f} GB ({avail:0.2f} avail)\nSwap used: {swapUsed:0.2f}/{swapTotal:0.2f} GB ({swapAvail:0.2f} avail)",
        "on-click": "alacritty -e htop",
    },
    "temperature": {
        "critical-threshold": 80,
        "interval": 5,
        "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": [
            "≤▒σ▒",
            "ΎΜΚ",
            "Ύζσ"
        ]
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": [
            "ΎΗΖ",
            "ΎΕΣ"
        ]
    },
    "wireplumber": {
        "format": "ΎΑρ {volume}%",
        "format-muted": "ΎΣο muted",
        "on-click": "select-default-audio",
        "on-click-right": "pavucontrol"
    },
    "bluetooth": {
        "format": "ΎΛΦ {status} {device_alias}",
        "on-click": "alacritty -e bluetoothctl",
        "on-click-right": "select-default-audio"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "{capacity}% ≤░ΓΕ",
        "format-plugged": "{capacity}% ΎΘο",
        "format-alt": "{time} {icon}",
        "format-icons": [
            "ΎΚΕ",
            "ΎΚΔ",
            "ΎΚΓ",
            "ΎΚΒ",
            "ΎΚΑ"
        ]
    },
    "network#wired": {
        "interface": "enp*",
        "format-ethernet": "{ifname}: {ipaddr}/{cidr} ≤░ΙΑ",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "≤░ΙΑ",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "alacritty -e nmtui"
    },
    "network#wireless": {
        "interface": "wlp*",
        "format-wifi": "{essid} {icon}",
        "format-linked": "{ifname} (No IP) ΎηΨ",
        "format-disconnected": "≤░Ψς",
        "tooltip-format-wifi": "{ifname}: {ipaddr}/{cidr}\nStrength: {signaldBm} dBm ({signalStrength}%)\nFrequency: {frequency} MHz",
        "on-click": "alacritty -e nmtui",
        "format-icons": ["≤░νψ", "≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"]
    },
    "custom/vpn": {
        "format": "≤░ΨΓ {}",
        "exec": "~/.config/waybar/vpn_status.sh",
        "interval": 30,
        "signal": 1,
        "return-type": "json",
        "on-click": "vpn"
    },
    "custom/voxtype": {
        "exec": "voxtype status --follow --format json",
        "return-type": "json",
        "format": "{icon}",
        "format-icons": {
            "idle": "≤░Ξυ",
            "recording": "ΎΕ░",
            "transcribing": "≤▒Κ║",
            "stopped": "≤░Ξφ"
        },
        "tooltip": true,
        "on-click": "systemctl --user restart voxtype"
    }
}
