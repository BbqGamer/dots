{
    "modules-left": [
        "sway/workspaces",
        "sway/mode",
        "custom/media",
    ],
    "modules-center": [
        "clock",
        "custom/voxtype"
    ],
    "modules-right": [
        "tray",
        "custom/wired",
        "network#wireless",
        "cpu",
        "memory",
        "custom/wireplumber",
        "battery",
    ],
    "clock": {
        "format": "{:%H:%M - %d/%m/%Y}"
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "tray": {
        "spacing": 10
    },
    "cpu": {
        "interval": 5,
        "format": "яТ╝ {usage}%",
        "tooltip": true,
        "on-click": "alacritty -e htop"
    },
    "memory": {
        "format": "яГЙ {percentage}%",
        "tooltip": true,
        "tooltip-format": " RAM used: {used:0.2f}/{total:0.2f} GB ({avail:0.2f} avail)\nSwap used: {swapUsed:0.2f}/{swapTotal:0.2f} GB ({swapAvail:0.2f} avail)",
        "on-click": "alacritty -e htop",
    },
    "temperature": {
        "critical-threshold": 80,
        "interval": 5,
        "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": [
            "ґ▒й▒",
            "яЛЙ",
            "яЭй"
        ]
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": [
            "яЖЕ",
            "яДС"
        ]
    },
    "custom/wireplumber": {
        "exec": "~/.config/waybar/wireplumber_status.sh",
        "return-type": "json",
        "interval": 2,
        "on-click": "select-default-audio",
        "on-click-right": "pavucontrol"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "{capacity}% ґ░ВД",
        "format-plugged": "{capacity}% яЗж",
        "format-alt": "{time} {icon}",
        "format-icons": [
            "яЙД",
            "яЙГ",
            "яЙВ",
            "яЙБ",
            "яЙА"
        ]
    },
    "custom/wired": {
        "exec": "~/.config/waybar/wired_status.sh",
        "return-type": "json",
        "interval": 5
    },
    "network#wireless": {
        "interface": "wl*",
        "format-wifi": "{essid} {icon}",
        "format-linked": "{ifname} (No IP) яЮЦ",
        "format-disconnected": "ґ░Цк",
        "tooltip-format-wifi": "{ifname}: {ipaddr}/{cidr}\nStrength: {signaldBm} dBm ({signalStrength}%)\nFrequency: {frequency} MHz",
        "on-click": "alacritty -e impala",
        "format-icons": ["ґ░дп", "ґ░дЯ", "ґ░дв", "ґ░де", "ґ░ди"]
    },
    "custom/vpn": {
        "format": "ґ░ЦВ {}",
        "exec": "~/.config/waybar/vpn_status.sh",
        "interval": 30,
        "signal": 1,
        "return-type": "json",
        "on-click": "vpn"
    },
    "custom/voxtype": {
        "exec": "voxtype status --follow --format json",
        "return-type": "json",
        "format": "{icon}",
        "format-icons": {
            "idle": "ґ░Нм",
            "recording": "яД░",
            "transcribing": "ґ▒Й║",
            "stopped": "ґ░Нн"
        },
        "tooltip": true,
        "on-click": "systemctl --user restart voxtype"
    }
}
